# Paperclip server configuration overrides.
# These are passed to the container alongside .env (which holds secrets).
# Non-secret configuration only.

PAPERCLIP_HOME=/data
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_PORT=3100
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DB_BACKUP_ENABLED=true
PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30
DO_NOT_TRACK=1
