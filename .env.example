# =============================================================================
# Paperclip Sandbox — Environment Variables
# =============================================================================
# Copy to .env and fill in with SCOPED, RATE-LIMITED keys only.
# See security/PLAYBOOK.md for credential safety guidelines.
# =============================================================================

# --- LLM Providers (use scoped keys with spend caps) ---
# ANTHROPIC_API_KEY=           # optional — alternative to subscription token via ./scripts/claude-login.sh
# OPENAI_API_KEY=              # optional — only needed for company templates that use OpenAI

# --- Paperclip Server ---
PAPERCLIP_PORT=3100
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# --- Telemetry (disabled by default for safety) ---
DO_NOT_TRACK=1

# --- Optional: External services for specific companies ---
# Uncomment and fill as needed per company use case.
# Only add service credentials after completing trust gates (see security/PLAYBOOK.md).
